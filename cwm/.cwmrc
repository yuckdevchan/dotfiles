# Unbind default CWM bindings
unbind-key CM-x
unbind-key M-Return
unbind-key CM-Return
unbind-key M-/
unbind-key CM-M
unbind-key CM-s

# Programs
bind-key CS-a "nitrogen --restore"
bind-key CS-s "xrandr --output HDMI-1-0 --mode 1920x1080"

## Terminal emulator
#bind-key M-Return "st"
bind-key M-Return "kitty"
## Run Launcher
bind-key M-d "rofi -show drun -show-icons -icon-theme "Paprius-Dark" -font "Hermit"
#bind-key M-d dmenu_run

bind-key M-c "kitty unimatrix -s 100"
bind-key M-b "librewolf"
bind-key M-s "pavucontrol -t 3"

# Window Management
bind-key MS-q window-close
bind-key M-f window-fullscreen
bind-key M-a window-hide
bind-key MS-s window-maximise

bind-key M-q menu-window

# X Audio Control
bind-key XF86AudioRaiseVolume "pactl set-sink-volume @DEFAULT_SINK@ +10%"
bind-key XF86AudioLowerVolume "pactl set-sink-volume @DEFAULT_SINK@ -10%"
bind-key XF86AudioMute "pactl set-sink-mute @DEFLT_SINK@ toggle"
bind-key XF86AudioPlay "playerctl play-pause"

# CWM Colour Scheme
#fontname "Hermit:pixelsize=12:bold"
borderwidth 0
color activeborder "#282a36"
color inactiveborder "#282a36"
color menubg "#282a36"
color menufg "#44475a"
color font "#f8f8f2"
color selfont "#f8f8f2"

# Applications Menu
command Librewolf librewolf
command GIMP gimp
command Firefox firefox
command Kdenlive Kdenlive
command VSCode vscodium
